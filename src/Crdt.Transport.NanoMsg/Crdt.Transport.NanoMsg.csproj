<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;netstandard2.1;net8.0;net9.0;net10.0</TargetFrameworks>
    <AssemblyName>Crdt.Transport.NanoMsg</AssemblyName>
    <RootNamespace>Crdt.Transport.NanoMsg</RootNamespace>
    <Description>Scalability-Protocols (BUS) gossip transport for Crdt.Transport, built on NanoMsgSharp (managed nanomsg/NNG over tcp, tls, ipc, ws, and inproc).</Description>
    <PackageTags>crdt;gossip;anti-entropy;replication;nanomsg;nng;scalability-protocols;bus</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Crdt.Transport\Crdt.Transport.csproj" />
    <PackageReference Include="NanoMsgSharp" />
  </ItemGroup>

  <!-- netstandard async dependencies (Span/PolySharp/Unsafe come from Directory.Build.props). -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" />
    <PackageReference Include="System.Threading.Tasks.Extensions" />
  </ItemGroup>

</Project>
